# --- Trading mode ---
TRADING_MODE=paper   # paper | live

# --- Risk limits ---
MAX_POSITION_PCT=5
MAX_CONCURRENT_POSITIONS=15
DAILY_LOSS_LIMIT_PCT=10
DRAWDOWN_KILL_SWITCH_PCT=30
CASH_RESERVE_PCT=30
MAX_TRADES_PER_DAY=50

# --- Strategy weights (sum to 1.0) ---
WEIGHT_KOL_MIRROR=0.30
WEIGHT_STRATEGY_REPL=0.40
WEIGHT_META_CYCLE=0.10
WEIGHT_ANOMALY=0.20
SIGNAL_CONFIDENCE_THRESHOLD=0.65

# --- KOL wallets to mirror ---
KOL_WALLETS=DNfuF1L62WWyW3pNakVkyGGFzVVhj4Yr52jSmdTyeBHm,HUpPyLU8KWisCAr3mzWy2FKT6uuxQ2qGgJQxyTpDoes5

# --- Gake strategy ---
NADIR_DRAWDOWN_MIN=0.70
NADIR_DRAWDOWN_MAX=0.90
MCAP_MIN_USD=100000
MCAP_PREFERRED_USD=1000000
EXIT_TAKE_PROFIT=2.0
EXIT_TRAILING_STOP=0.20

# --- Data providers ---
HELIUS_API_KEY=
